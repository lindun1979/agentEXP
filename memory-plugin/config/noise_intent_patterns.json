{
  "matching_mode": "case_insensitive",
  "patterns": [
    {
      "name": "weather",
      "regex": "(天气|weather)",
      "action": "short_circuit"
    },
    {
      "name": "interview_java",
      "regex": "(Java.*面试题|面试题.*Java)",
      "action": "short_circuit"
    },
    {
      "name": "explicit_memory_request",
      "regex": "(记忆|memory|STATE|MEMORY\\.md)",
      "action": "exclude"
    }
  ]
}
